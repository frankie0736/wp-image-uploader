# Docker部署环境变量配置

# 宿主机端口设置（默认3001）
HOST_PORT=3001

# 如果需要使用不同端口，可以修改为：
# HOST_PORT=8080
# HOST_PORT=3333

# WordPress图片上传工具 - 环境变量配置

# 授权Token (用于API访问验证)
WP_AUTH_TOKEN=wp-img-auth-2024-fx-token-9k8j7h6g5f4d3s2a1z

# 数据库连接配置 (Neon PostgreSQL)
# 格式: postgresql://username:password@hostname:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@hostname:5432/database?sslmode=require

# 服务器端口
PORT=3001

# 文件上传配置
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads

# 跨域配置
CORS_ORIGIN=*

# 开发环境配置
NODE_ENV=production 